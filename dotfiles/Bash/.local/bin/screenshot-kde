#!/usr/bin/env bash
set -euo pipefail

# 临时文件
tmp_pic=$(mktemp --suffix=.png)
trap 'rm -f "$tmp_pic"' EXIT

# spectacle 截图
spectacle -b -n -r -o "$tmp_pic" > /dev/null 2>&1

# mpv 贴图 (KDE需要添加KWin规则保持窗口置顶: MPV_Pinned)
mpv "$tmp_pic" \
    --title="MPV_Pinned_${tmp_pic##*/}" \
    --script="$HOME/.config/mpv/scripts/pin_image.lua" \
    --no-config --no-input-builtin-bindings > /dev/null 2>&1

