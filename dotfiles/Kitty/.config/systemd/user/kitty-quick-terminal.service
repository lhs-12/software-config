[Unit]
Description=Kitty Quick Access Terminal
After=graphical-session.target

[Service]
Type=simple
ExecStartPre=-/usr/bin/pkill -TERM -f "kitty.*kitten.*quick-access"
ExecStop=-/usr/bin/pkill -TERM -f "kitty.*kitten.*quick-access"
ExecStart=/usr/bin/kitten quick_access_terminal
Restart=on-failure
KillMode=none

[Install]
WantedBy=default.target